# Pega aquí la connection string de Neon, Supabase o Railway:
# Ejemplo Neon:     postgresql://usuario:password@ep-xxx.us-east-2.aws.neon.tech/solvitech_db
# Ejemplo Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL=postgresql://USUARIO:PASSWORD@HOST/NOMBRE_BD
